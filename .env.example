# ─── Flask Configuration ──────────────────────────────────────────────────────
FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change_this_to_a_random_secret_key_min_32_chars
PORT=5000

# ─── File Storage ─────────────────────────────────────────────────────────────
UPLOAD_FOLDER=./uploads
REPORTS_FOLDER=./reports
MAX_CONTENT_LENGTH=16777216

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_PATH=./backend/database/crack_detection.db

# ─── AI Model ─────────────────────────────────────────────────────────────────
MODEL_PATH=./trained_model/crack_cnn.h5
IMAGE_SIZE=224
CONFIDENCE_THRESHOLD=0.60

# ─── Optional: Email Alerts for Critical Severity ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
ALERT_EMAIL=admin@yourproject.com
ENABLE_EMAIL_ALERTS=false
